    [IsTopologicalGroup H₁] [IsTopologicalGroup H₂] in
/-- Right composite of the canonical comparison map between profinite pushout objects.
-/
@[simp 900] theorem pushoutContMapOfIsPushout_right
    {α₁ : H₁ →ₜ* G} {α₂ : H₂ →ₜ* G}
    {α₁' : H₁ →ₜ* G'} {α₂' : H₂ →ₜ* G'}
    (β₁ : H →ₜ* H₁) (β₂ : H →ₜ* H₂)
    (hpo : HasProfiniteTestPushoutProperty β₁ β₂ α₁ α₂)
    (hpo' : HasProfiniteTestPushoutProperty β₁ β₂ α₁' α₂')
    (hG' : IsProfiniteGroup G') :
    (pushoutContMapOfIsPushout β₁ β₂ hpo hpo' hG').comp α₂ = α₂' :=
