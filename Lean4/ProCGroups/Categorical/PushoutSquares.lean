/-- Left composite of the canonical continuous pushout equivalence.
-/
@[simp] theorem pushoutContEquivOfIsPushout_left
    {α₁ : H₁ →ₜ* G} {α₂ : H₂ →ₜ* G}
    {α₁' : H₁ →ₜ* G'} {α₂' : H₂ →ₜ* G'}
    (β₁ : H →ₜ* H₁) (β₂ : H →ₜ* H₂)
    (hpo : HasProfiniteTestPushoutProperty β₁ β₂ α₁ α₂)
    (hpo' : HasProfiniteTestPushoutProperty β₁ β₂ α₁' α₂')
    (hG : IsProfiniteGroup G) (hG' : IsProfiniteGroup G') :
    ((pushoutContEquivOfIsPushout β₁ β₂ hpo hpo' hG hG' : G →ₜ* G').comp α₁) = α₁' := by
  change (pushoutContMapOfIsPushout β₁ β₂ hpo hpo' hG').comp α₁ = α₁'
  exact pushoutContMapOfIsPushout_left β₁ β₂ hpo hpo' hG'

